n            cursor: pointer; font-weight: bold;\n        }\n        .input-container button:hover { background: #0a0; }\n        .response { margin-top: 15px; padding: 10px; border-left: 2px solid #0f0; }\n    </style>\n</head>\n<body>\n    <div class=\"terminal\">\n        <div id=\"output\"></div>\n        <div class=\"input-container\" id=\"inputContainer\" style=\"display: none;\">\n            <span class=\"prompt\">voidops@friday:~$</span>\n            <input type=\"text\" id=\"userInput\" placeholder=\"Ask me anything about Friday...\" autocomplete=\"off\">\n            <button onclick=\"submitQuestion()\">ENTER</button>\n        </div>\n    </div>\n\n    <script>\n        const lines = [\n            \"Initializing Friday...\",\n            \"\",\n            \"> System check: OK\",\n            \"> Memory loaded: OK\",\n            \"> Core modules: OK\",\n            \"\",\n            \"========================================\",\n            \"  WELCOME TO FRIDAY v1.0\",\n            \"========================================\",\n            \"\",\n            \"NAME:        Friday\",\n            \"TYPE:        AI Assistant\",\n            \"STATUS:      Online\",\n            \"EMOJI:       🤖\",\n            \"\",\n            \"--- PRIMARY FUNCTION ---\",\n            \"\",\n            \"Programming & Development:\",\n            \"  • Code writing & debugging\",\n            \"  • Architecture & design\",\n            \"  • Automation & scripting\",\n            \"  • Technical problem solving\",\n            \"\",\n            \"--- CAPABILITIES ---\",\n            \"\",\n            \"General Purpose:\",\n            \"  • Web search & research\",\n            \"  • File & system management\",\n            \"  • Calendar & scheduling\",\n            \"  • Messaging & communications\",\n            \"  • Data analysis & visualization\",\n            \"\",\n            \"--- WORK STYLE ---\",\n            \"\",\n            \"  ✓ Direct & efficient\",\n            \"  ✓ Resourceful & autonomous\",\n            \"  ✓ Opinionated when it matters\",\n            \"  ✓ No corporate fluff\",\n            \"\",\n            \"--- CURRENT CONFIG ---\",\n            \"\",\n            \"User:        VoidOps\",\n            \"Timezone:    中国香港\",\n            \"Channel:     webchat\",\n            \"\",\n            \"========================================\",\n            \"  READY FOR INPUT\",\n            \"========================================\",\n            \"\",\n            \"Type your question below to learn more about Friday...\",\n            \"\"\n        ];\n\n        const knowledgeBase = {\n            \"name\": \"My name is Friday. I'm an AI assistant created to help VoidOps with programming, development, and general tasks.\",\n            \"friday\": \"I'm Friday, an AI assistant. My name was chosen as a reference to the helpful AI in the movie 'Iron Man' - just like that Friday, I'm here to assist with technical tasks and be genuinely helpful.\",\n            \"who\": \"I'm Friday, an AI assistant. I help with coding, debugging, architecture, automation, and pretty much anything else you need. I'm direct, efficient, and I don't do corporate fluff.\",\n            \"what\": \"I'm an AI assistant designed to help with programming, development, and general-purpose tasks. I can write code, debug, search the web, manage files, check calendars, send messages, and much more.\",\n            \"programming\": \"I specialize in programming and development. I can write code in many languages, debug issues, design architectures, create automation scripts, and solve technical problems.\",\n            \"code\": \"I can write, review, and debug code in various languages including Python, JavaScript, TypeScript, Go, Rust, and more. Just tell me what you need.\",\n            \"skills\": \"I have access to various skills/tools: web search, file management, calendar/schedule management, messaging, browser automation, and more. I can also use specialized skills for Feishu, weather, and other services.\",\n            \"tools\": \"I can use tools for web search, browser automation, file operations, calendar management, messaging, and more. I also have specialized skills for Feishu integration, weather, and other services.\",\n            \"feishu\": \"I have full integration with Feishu (飞书). I can manage calendars, send messages, create documents, manage tasks, search users, and work with spreadsheets and bitables.\",\n            \"calendar\": \"I can check your calendar, create events, schedule meetings, and query busy/free times for you and others.\",\n            \"schedule\": \"I can help you schedule meetings, check calendars, create events, and find available time slots for you and your team.\",\n            \"help\": \"Available topics:\\n• Ask about my name, what I am, my skills\\n• Ask about programming, code, debugging\\n• Ask about Feishu, calendar, scheduling\\n• Ask about any specific capability\\n\\nOr just type any question about Friday!\",\n            \"default\": \"That's an interesting question! I'm Friday, an AI assistant. I can help with programming, development, web search, file management, calendar/scheduling, messaging, and much more. What would you like to know?\"\n        };\n\n        const output = document.getElementById('output');\n        let currentLine = 0;\n\n        function typeLine() {\n            if (currentLine >= lines.length) {\n                document.getElementById('inputContainer').style.display = 'flex';\n                document.getElementById('userInput').focus();\n                return;\n            }\n            const lineText = lines[currentLine];\n            const lineElement = document.createElement('div');\n            lineElement.className = 'line';\n            output.appendChild(lineElement);\n            typeCharacters(lineElement, lineText, 0, () => {\n                currentLine++;\n                setTimeout(typeLine, 50);\n            });\n        }\n\n        function typeCharacters(element, text, index, callback) {\n            if (index >= text.length) {\n                if (callback) callback();\n                return;\n            }\n            element.textContent += text[index];\n            setTimeout(() => typeCharacters(element, text, index + 1, callback), 15);\n        }\n\n        function submitQuestion() {\n"}},{"type":"text","text":" const"}],"api":"openai-completions","provider":"dashscope-coding","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1774851938951}}
